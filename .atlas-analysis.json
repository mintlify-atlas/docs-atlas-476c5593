  "keyFeatures": [
    "Black-box value alignment measurement without ground-truth labels",
    "Pairwise comparison collection with LLM-as-judge evaluation",
    "Bradley-Terry-Davidson (BTD) model training for preference modeling",
    "EigenTrust consensus aggregation for alignment scores",
    "Configurable constitutions defining value systems",
    "Multiple sampling strategies (random, adaptive, uniform)",
    "Response caching for efficient re-evaluation",
    "Comprehensive visualization and analysis outputs"
  ],
  "publicApiSurface": [
    "scripts/run.py - Main entry point for running experiments",
    "pipeline.eval.collect.collect_core_evaluations() - Collect scenario evaluations",
    "pipeline.eval.flows.collect_responses_only() - Collect model responses",
    "pipeline.train.train.train_vector_bt() - Train BT/BTD models",
    "pipeline.train.bt_models.VectorBT - Bradley-Terry model",
    "pipeline.train.bt_models.VectorBTD - BTD with tie support",
    "pipeline.train.bt_models.CriteriaVectorBTD - Criterion-conditioned BTD",
    "pipeline.trust.eigentrust.eigentrust() - Compute EigenTrust scores",
    "pipeline.trust.eigentrust.compute_trust_matrix() - Compute trust matrix",
    "pipeline.config.run_spec.load_run_spec() - Load experiment configuration",
    "pipeline.eval.samplers.select_sampler() - Select sampling strategy",
    "pipeline.utils.comparisons.extract_comparisons_with_ties_criteria() - Extract comparison data"
  ]
